APP_NAME=AlphaQuant AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
WORKERS=2
TIMEZONE=Asia/Shanghai

JWT_SECRET_KEY=change-me-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

DATABASE_ENGINE=postgresql
DATABASE_URL=postgresql+asyncpg://alphaquant:alphaquant@postgres:5432/alphaquant
DATABASE_ECHO=false

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

LOG_LEVEL=INFO
LOG_DIR=logs

AI_DEFAULT_PROVIDER=deepseek
AI_ENABLED_PROVIDERS=deepseek
AI_ANALYSIS_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=

STOCK_DEFAULT_MARKET=A
STOCK_DEFAULT_PROVIDER=akshare
STOCK_PROVIDER_PRIORITY=akshare,eastmoney,sina,tencent,tushare,baostock
TUSHARE_TOKEN=
ALPHA_VANTAGE_API_KEY=

SCHEDULER_ENABLED=true
WEBSOCKET_ENABLED=true

